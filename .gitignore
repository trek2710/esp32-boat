# PlatformIO
.pio/
.pioenvs/
.piolibdeps/
.vscode/
.clangd/
.cache/

# Build artifacts
*.bin
*.elf
*.map
*.o
*.a
build/

# ...but allow committed pre-built firmware in binaries/
!binaries/
!binaries/**/*.bin

# Python (if we add tooling)
__pycache__/
*.pyc
.venv/
venv/

# OS cruft
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/

# Secrets (WiFi creds, OTA passwords, etc.)
secrets.h
.env
CLAUDE.md

# Per-clone state — `flash.sh` registers each board's MAC here so it can
# refuse to flash the wrong device. Different machines will have different
# boards, so this isn't shareable across clones.
scripts/.devices.conf
